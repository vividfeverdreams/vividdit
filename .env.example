# --- Supabase ---
# Local dev: values come from `supabase status` after `supabase start`.
# Production: from the Supabase project dashboard (Settings → API).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Bypasses RLS — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- BYOK key encryption (server-only) ---
# 32-byte base64 secret used for AES-256-GCM encryption of creator OpenAI keys.
# Generate with: openssl rand -base64 32
API_KEY_ENCRYPTION_SECRET=

# --- Email (Resend) ---
# Optional in dev: when unset, fan emails are logged to the console instead of sent.
RESEND_API_KEY=
EMAIL_FROM="Vividdit <noreply@example.com>"
